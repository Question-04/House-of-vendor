# PostgreSQL (production: Neon/Render Postgres URL with sslmode=require)
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Render sets PORT automatically; optional locally
PORT=8080

# production | development
APP_ENV=production

# MSG91 — same auth key as main site if you share OTP/widget account
MSG91_AUTH_KEY=

# --- Cloudflare R2 (S3-compatible; required by server for KYC uploads) ---
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Public URL if bucket is exposed via R2 custom domain / public bucket; else leave empty
R2_PUBLIC_BASE_URL=

# Vendor frontend origin (no trailing slash) — used for links / CORS-related config
FRONTEND_BASE_URL=https://your-vendor-frontend.vercel.app

# Dev-only: bypass for testing file routes. Leave EMPTY in production.
DEV_FILE_ACCESS_KEY=

# Admin API — must match frontend ADMIN_JWT_SECRET (min 16 chars)
ADMIN_JWT_SECRET=

# Comma-separated admin phones (normalized to 91… in code)
ADMIN_PHONE_ALLOWLIST=919999999999

# Optional: tighten CORS to your Vercel domain
# ADMIN_CORS_ORIGIN=https://your-vendor-frontend.vercel.app

# Optional trusted header for non-browser callers
# ADMIN_INTERNAL_SECRET=

# NEVER set in production — local/testing only
# MAGIC_OTP=
# ENABLE_MAGIC_OTP=false
