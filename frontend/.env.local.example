# Public site URL (no trailing slash). Used for canonical links, Open Graph / WhatsApp previews, and sitemap.
# Local: http://localhost:3000  |  Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API base URL (no trailing slash)
# Local: http://localhost:8080
# With ngrok (e.g. testing from phone): use backend ngrok URL, e.g. https://abc123.ngrok-free.app
NEXT_PUBLIC_API_URL=http://localhost:8080

# MSG91 OTP Widget (from MSG91 dashboard → OTP Widget)
# Widget ID shown in widget setup
NEXT_PUBLIC_MSG91_WIDGET_ID=366274716244313138363332
# Token Auth from same widget (sometimes called "Token" or "Auth token")
NEXT_PUBLIC_MSG91_TOKEN_AUTH=your_token_auth_here

# --- Admin dashboard (MSG91 OTP → NextAuth Credentials → BFF → Go /api/admin/*) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_long_random_string

# Comma-separated admin phone numbers allowed to sign in at /admin (MSG91 OTP).
# Phones are normalized: 10 digits => prefixed with 91.
ADMIN_HOV_PHONE_ALLOWLIST=919999999999

# Same secret as backend ADMIN_JWT_SECRET (min 16 chars); used only on the server to mint short-lived JWTs for the Go API
ADMIN_JWT_SECRET=

# Server-side base URL for the Go vendor API (not exposed to the browser). Defaults to NEXT_PUBLIC_API_URL.
# Production: set to your Render service URL (https://api.yourdomain.com), not localhost.
INTERNAL_VENDOR_API_URL=http://localhost:8080

# If you add a dev file-download helper that sends a header matching backend DEV_FILE_ACCESS_KEY, set it here.
# Must match backend DEV_FILE_ACCESS_KEY. Leave unset in production if that route is disabled.
# NEXT_PUBLIC_DEV_FILE_ACCESS_KEY=
